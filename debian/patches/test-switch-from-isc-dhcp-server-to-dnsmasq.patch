diff --git a/test/TEST-60-NFS/dnsmasq.conf b/test/TEST-60-NFS/dnsmasq.conf
new file mode 100644
index 0000000..11af317
--- /dev/null
+++ b/test/TEST-60-NFS/dnsmasq.conf
@@ -0,0 +1,95 @@
+dhcp-leasefile=/run/dnsmasq.leases
+log-debug
+#log-dhcp
+log-facility=-
+no-hosts
+no-ping
+no-resolv
+user=root
+group=root
+pid-file=
+
+# net50
+interface=enx525400123456
+tag-if=set:net50,tag:enx525400123456
+dhcp-range=tag:net50,192.168.50.200,192.168.50.250,255.255.255.0
+dhcp-option=tag:net50,option:domain-name,net50.test
+dhcp-option=tag:net50,option:tftp-server,192.168.50.1
+
+# MAC numbering scheme:
+# NFSv3: last octet starts at 0x00 and works up
+# NFSv4: last octet starts at 0x80 and works up
+
+# NFSv3 root=dhcp or root={/dev/,}nfs, use server-id
+dhcp-host=52:54:00:12:34:00,tag:net50,set:nfs3-0,192.168.50.100,nfs3-0
+dhcp-option=tag:nfs3-0,option:root-path,"/nfs/client"
+
+# NFSv3 Legacy root=/dev/nfs nfsroot=IP:path
+dhcp-host=52:54:00:12:34:01,tag:net50,set:nfs3-1,192.168.50.101,nfs3-1
+dhcp-option=tag:nfs3-1,option:root-path,"192.168.50.2:/nfs/client"
+
+# NFSv3 Legacy root=/dev/nfs DHCP path only
+dhcp-host=52:54:00:12:34:02,tag:net50,set:nfs3-2,192.168.50.102,nfs3-2
+dhcp-option=tag:nfs3-2,option:root-path,"/nfs/client"
+
+# NFSv3 Legacy root=/dev/nfs DHCP IP:path
+dhcp-host=52:54:00:12:34:03,tag:net50,set:nfs3-3,192.168.50.103,nfs3-3
+dhcp-option=tag:nfs3-3,option:root-path,"192.168.50.2:/nfs/client"
+
+# NFSv3 root=dhcp DHCP IP:path
+dhcp-host=52:54:00:12:34:04,tag:net50,set:nfs3-4,192.168.50.104,nfs3-4
+dhcp-option=tag:nfs3-4,option:root-path,"192.168.50.2:/nfs/client"
+
+# NFSv3 root=dhcp DHCP proto:IP:path
+dhcp-host=52:54:00:12:34:05,tag:net50,set:nfs3-5,192.168.50.105,nfs3-5
+dhcp-option=tag:nfs3-5,option:root-path,"nfs:192.168.50.3:/nfs/client"
+
+# NFSv3 root=dhcp DHCP proto:IP:path:options
+dhcp-host=52:54:00:12:34:06,tag:net50,set:nfs3-6,192.168.50.106,nfs3-6
+dhcp-option=tag:nfs3-6,option:root-path,"nfs:192.168.50.3:/nfs/client:wsize=4096"
+
+# NFSv3 root=nfs:...
+dhcp-host=52:54:00:12:34:07,tag:net50,set:nfs3-7,192.168.50.107,nfs3-7
+
+# NFSv3 Bridge root=nfs:...
+dhcp-host=52:54:00:12:34:08,tag:net50,set:nfs3-8,192.168.50.108,nfs3-8
+
+# NFSv3 Legacy root=IP:path
+dhcp-host=52:54:00:12:34:09,tag:net50,set:nfs3-9,192.168.50.109,nfs3-9
+
+# NFSv3 root=dhcp DHCP path,options
+dhcp-host=52:54:00:12:34:10,tag:net50,set:nfs3-10,192.168.50.110,nfs3-10
+dhcp-option=tag:nfs3-10,option:root-path,"/nfs/client,wsize=4096"
+
+# NFSv3 root=dhcp DHCP IP:path,options
+dhcp-host=52:54:00:12:34:11,tag:net50,set:nfs3-11,192.168.50.111,nfs3-11
+dhcp-option=tag:nfs3-11,option:root-path,"192.168.50.2:/nfs/client,wsize=4096"
+
+# NFSv3 root=dhcp DHCP proto:IP:path,options
+dhcp-host=52:54:00:12:34:12,tag:net50,set:nfs3-12,192.168.50.112,nfs3-12
+dhcp-option=tag:nfs3-12,option:root-path,"nfs:192.168.50.3:/nfs/client,wsize=4096"
+
+# NFSv3 Bridge Customized root=dhcp DHCP path,options
+dhcp-host=52:54:00:12:34:13,tag:net50,set:nfs3-13,192.168.50.113,nfs3-13
+dhcp-option=tag:nfs3-13,option:root-path,"/nfs/client,wsize=4096"
+
+# NFSv4 root=dhcp DHCP proto:IP:path
+dhcp-host=52:54:00:12:34:80,tag:net50,set:nfs4-0,192.168.50.180,nfs4-0
+dhcp-option=tag:nfs4-0,option:root-path,"nfs4:192.168.50.3:/client"
+
+# NFSv4 root=dhcp DHCP proto:IP:path:options
+dhcp-host=52:54:00:12:34:81,tag:net50,set:nfs4-1,192.168.50.181,nfs4-1
+dhcp-option=tag:nfs4-1,option:root-path,"nfs4:192.168.50.3:/client:wsize=4096"
+
+# NFSv4 root=nfs4:...
+dhcp-host=52:54:00:12:34:82,tag:net50,set:nfs4-2,192.168.50.182,nfs4-2
+
+# NFSv4 root=dhcp DHCP proto:IP:path,options
+dhcp-host=52:54:00:12:34:83,tag:net50,set:nfs4-3,192.168.50.183,nfs4-3
+dhcp-option=tag:nfs4-3,option:root-path,"nfs4:192.168.50.3:/client,wsize=4096"
+
+# NFSv4 Overlayfs root=nfs4:...
+dhcp-host=52:54:00:12:34:84,tag:net50,set:nfs4-4,192.168.50.184,nfs4-4
+
+# NFSv4 Live Overlayfs root=nfs4:...
+dhcp-host=52:54:00:12:34:85,tag:net50,set:nfs4-5,192.168.50.185,nfs4-5
diff --git a/test/TEST-60-NFS/server-init.sh b/test/TEST-60-NFS/server-init.sh
index e9482d8..cff7bc6 100755
--- a/test/TEST-60-NFS/server-init.sh
+++ b/test/TEST-60-NFS/server-init.sh
@@ -91,14 +91,11 @@ command -v rpc.idmapd > /dev/null && [ -z "$(pidof rpc.idmapd)" ] && rpc.idmapd
 : > /dev/watchdog
 exportfs -r
 : > /dev/watchdog
-mkdir -p /var/lib/dhcpd
-: > /var/lib/dhcpd/dhcpd.leases
+dnsmasq
 : > /dev/watchdog
-chmod 777 /var/lib/dhcpd/dhcpd.leases
-: > /dev/watchdog
-rm -f /var/run/dhcpd.pid
-dhcpd -d -cf /etc/dhcpd.conf -lf /var/lib/dhcpd/dhcpd.leases &
 exportfs -s
+# tcpdump is a workaround for https://github.com/dracut-ng/dracut-ng/issues/2283
+tcpdump -Z root -i enx525400123456 -n port 67 or port 68 &
 echo "Serving NFS mounts"
 while :; do
     [ -n "$(jobs -rp)" ] && : > /dev/watchdog
