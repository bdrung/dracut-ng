From: Vitaly Kuznetsov <vkuznets@redhat.com>
Date: Mon, 13 Apr 2026 15:23:08 +0200
Subject: fix: avoid arguments for dot commands

Dot commands don't support arguments in Dash/ posix shell, this is
SC2240. Use 'set' instead.

Fixes: https://github.com/dracut-ng/dracut-ng/issues/346
Origin: upstream, https://github.com/dracut-ng/dracut-ng/pull/2384
---
 modules.d/80base/dracut-lib.sh   | 4 ++--
 modules.d/86shutdown/shutdown.sh | 7 +++++--
 2 files changed, 7 insertions(+), 4 deletions(-)

diff --git a/modules.d/80base/dracut-lib.sh b/modules.d/80base/dracut-lib.sh
index 21322d7..339567d 100755
--- a/modules.d/80base/dracut-lib.sh
+++ b/modules.d/80base/dracut-lib.sh
@@ -394,9 +394,9 @@ source_hook() {
     _dir=$1
     shift
     for f in $(list_hooks "$_dir"); do
+        set -- "$@"
         # shellcheck disable=SC1090
-        # shellcheck disable=SC2240
-        . "$f" "$@"
+        . "$f"
     done
 }
 
diff --git a/modules.d/86shutdown/shutdown.sh b/modules.d/86shutdown/shutdown.sh
index 15f12b5..0c1d585 100755
--- a/modules.d/86shutdown/shutdown.sh
+++ b/modules.d/86shutdown/shutdown.sh
@@ -131,8 +131,11 @@ _check_shutdown() {
     local __f
     local __s=0
     for __f in $(list_hooks "shutdown"); do
-        # shellcheck disable=SC1090 disable=SC2240
-        if (final="$1" . "$__f" "$1"); then
+        if (
+            set -- "$1"
+            # shellcheck disable=SC1090
+            final="$1" . "$__f"
+        ); then
             rm -f -- "$__f"
         else
             __s=1
