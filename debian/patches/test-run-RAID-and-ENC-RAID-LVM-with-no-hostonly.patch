From: Benjamin Drung <benjamin.drung@canonical.com>
Date: Fri, 20 Dec 2024 20:34:09 +0100
Subject: test: run RAID and ENC-RAID-LVM with --no-hostonly
MIME-Version: 1.0
Content-Type: text/plain; charset="utf-8"
Content-Transfer-Encoding: 8bit

The dracut 105-2ubuntu4 upstream-dracut-core autopkgtest hangs. The
TEST-13-ENC-RAID-LVM asks for luks password:

```
TEST: root filesystem on an encrypted LVM PV on a RAID-5
[...]
[ 0.000000] Command line: rd.retry=10 rd.info rd.shell=0 panic=1 oops=panic softlockup_panic=1 systemd.crash_reboot console=ttyS0,115200n81 root=/dev/dracut/root rd.auto
[...]
Starting systemd-cryptsetup@luks\x…309a-5a90-4ae8-acdc-ee47b42a6ee8...

Please enter passphrase for disk luks-b51f309a-5a90-4ae8-acdc-ee47b42a6ee8: (press TAB for no echo)
```

Bug: https://github.com/dracut-ng/dracut-ng/issues/1057
Bug-Ubuntu: https://bugs.launchpad.net/bugs/2091954
---
 test/TEST-10-RAID/test.sh         | 2 +-
 test/TEST-12-RAID-DEG/test.sh     | 2 +-
 test/TEST-13-ENC-RAID-LVM/test.sh | 2 +-
 3 files changed, 3 insertions(+), 3 deletions(-)

diff --git a/test/TEST-10-RAID/test.sh b/test/TEST-10-RAID/test.sh
index b82cb9b..50cc8a2 100755
--- a/test/TEST-10-RAID/test.sh
+++ b/test/TEST-10-RAID/test.sh
@@ -57,7 +57,7 @@ test_setup() {
     echo "testluks UUID=$ID_FS_UUID /etc/key" > /tmp/crypttab
     echo -n "test" > /tmp/key
 
-    test_dracut \
+    test_dracut --no-hostonly \
         -a "crypt lvm mdraid" \
         -i "./cryptroot-ask.sh" "/sbin/cryptroot-ask" \
         -i "/tmp/crypttab" "/etc/crypttab" \
diff --git a/test/TEST-12-RAID-DEG/test.sh b/test/TEST-12-RAID-DEG/test.sh
index 7170215..290a351 100755
--- a/test/TEST-12-RAID-DEG/test.sh
+++ b/test/TEST-12-RAID-DEG/test.sh
@@ -96,7 +96,7 @@ test_setup() {
     echo -n test > /tmp/key
     chmod 0600 /tmp/key
 
-    test_dracut \
+    test_dracut --no-hostonly \
         -m "crypt lvm mdraid kernel-modules" \
         -i "./cryptroot-ask.sh" "/sbin/cryptroot-ask" \
         -i "/tmp/mdadm.conf" "/etc/mdadm.conf" \
diff --git a/test/TEST-13-ENC-RAID-LVM/test.sh b/test/TEST-13-ENC-RAID-LVM/test.sh
index 4211ef9..16001c8 100755
--- a/test/TEST-13-ENC-RAID-LVM/test.sh
+++ b/test/TEST-13-ENC-RAID-LVM/test.sh
@@ -97,7 +97,7 @@ test_setup() {
     echo -n test > /tmp/key
     chmod 0600 /tmp/key
 
-    test_dracut \
+    test_dracut --no-hostonly \
         -a "crypt lvm mdraid" \
         -i "./cryptroot-ask.sh" "/sbin/cryptroot-ask" \
         -i "/tmp/crypttab" "/etc/crypttab" \
