From: Benjamin Drung <benjamin.drung@canonical.com>
Date: Fri, 20 Dec 2024 20:34:09 +0100
Subject: test: run RAID and ENC-RAID-LVM with --no-hostonly
MIME-Version: 1.0
Content-Type: text/plain; charset="utf-8"
Content-Transfer-Encoding: 8bit

The dracut 105-2ubuntu4 upstream-dracut-core autopkgtest hangs. The
TEST-26-ENC-RAID-LVM asks for luks password:

```
TEST: root filesystem on an encrypted LVM PV on a RAID-5
[...]
[ 0.000000] Command line: rd.retry=10 rd.info rd.shell=0 panic=1 oops=panic softlockup_panic=1 systemd.crash_reboot console=ttyS0,115200n81 root=/dev/dracut/root rd.auto
[...]
Starting systemd-cryptsetup@luks\x…309a-5a90-4ae8-acdc-ee47b42a6ee8...

Please enter passphrase for disk luks-b51f309a-5a90-4ae8-acdc-ee47b42a6ee8: (press TAB for no echo)
```

Bug: https://github.com/dracut-ng/dracut-ng/issues/1057
Bug-Ubuntu: https://bugs.launchpad.net/bugs/2091954
---
 test/TEST-20-STORAGE/test.sh      | 2 +-
 test/TEST-26-ENC-RAID-LVM/test.sh | 2 +-
 2 files changed, 2 insertions(+), 2 deletions(-)

diff --git a/test/TEST-20-STORAGE/test.sh b/test/TEST-20-STORAGE/test.sh
index 7f49bd0..54ee74b 100755
--- a/test/TEST-20-STORAGE/test.sh
+++ b/test/TEST-20-STORAGE/test.sh
@@ -159,7 +159,7 @@ test_setup() {
     fi
 
     # shellcheck disable=SC2046
-    test_dracut \
+    test_dracut --no-hostonly \
         -a "lvm" \
         $(if command -v mdadm > /dev/null; then echo "-a mdraid"; fi) \
         $(if command -v cryptsetup > /dev/null; then echo "-a crypt"; fi) \
diff --git a/test/TEST-26-ENC-RAID-LVM/test.sh b/test/TEST-26-ENC-RAID-LVM/test.sh
index 6ba637c..ad8adff 100755
--- a/test/TEST-26-ENC-RAID-LVM/test.sh
+++ b/test/TEST-26-ENC-RAID-LVM/test.sh
@@ -97,7 +97,7 @@ test_setup() {
     echo -n test > /tmp/key
     chmod 0600 /tmp/key
 
-    test_dracut \
+    test_dracut --no-hostonly \
         -a "crypt lvm mdraid" \
         -i "/tmp/crypttab" "/etc/crypttab" \
         -i "/tmp/key" "/etc/key" \
