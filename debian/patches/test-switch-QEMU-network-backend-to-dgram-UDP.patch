 test/TEST-60-NFS/test.sh         | 8 ++++----
 test/TEST-70-ISCSI/test.sh       | 8 ++++----
 test/TEST-71-ISCSI-MULTI/test.sh | 8 ++++----
 test/TEST-72-NBD/test.sh         | 8 ++++----
 4 files changed, 16 insertions(+), 16 deletions(-)

