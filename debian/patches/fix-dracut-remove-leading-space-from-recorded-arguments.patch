From: Benjamin Drung <benjamin.drung@canonical.com>
Date: Fri, 10 Apr 2026 23:07:19 +0200
Subject: fix(dracut): remove leading space from recorded arguments

`/lib/dracut/build-parameter.txt` records the dracut arguments, but
contains a leading space.

Remove the leading space when recording the arguments.

Forwarded: https://github.com/dracut-ng/dracut-ng/pull/2370
---
 dracut.sh | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/dracut.sh b/dracut.sh
index 06d2922..13e06b3 100755
--- a/dracut.sh
+++ b/dracut.sh
@@ -603,7 +603,7 @@ eval set -- "$TEMP"
 
 while :; do
     if [[ $1 != "--" ]] && [[ $1 != "--rebuild" ]]; then
-        PARMS_TO_STORE+=" $1"
+        PARMS_TO_STORE="${PARMS_TO_STORE:+$PARMS_TO_STORE }$1"
     fi
     case $1 in
         --kver)
@@ -941,7 +941,7 @@ while (($# > 0)); do
     if [ "${1%%=*}" == "++include" ]; then
         include_src+=("$2")
         include_target+=("$3")
-        PARMS_TO_STORE+=" --include '$2' '$3'"
+        PARMS_TO_STORE="${PARMS_TO_STORE:+$PARMS_TO_STORE }--include '$2' '$3'"
         shift 2
     fi
     shift
