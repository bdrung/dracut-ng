From: gomid4497 <rakeshw728@gmail.com>
Date: Mon, 13 Apr 2026 15:01:15 +0530
Subject: fix(iscsi): handle empty URI in firmware boot mode

When rd.iscsi.firmware=1 is set, netroot is either 'iscsi' or 'iscsi:'
with no real URI. parse_iscsi_root() was called with these values causing
'shift count out of range' errors as shift was called on empty positional
parameters.

Add two guards in parse_iscsi_root() to return early when there are no
parameters left to parse, and skip handle_netroot() in iscsiroot.sh when
netroot has no real target.

Fixes: https://github.com/dracut-ng/dracut-ng/issues/1701
Bug-Ubuntu: https://launchpad.net/bugs/2121865
Forwarded: https://github.com/dracut-ng/dracut-ng/pull/2382
---
 modules.d/45net-lib/net-lib.sh | 1 +
 modules.d/74iscsi/iscsiroot.sh | 2 +-
 2 files changed, 2 insertions(+), 1 deletion(-)

diff --git a/modules.d/45net-lib/net-lib.sh b/modules.d/45net-lib/net-lib.sh
index a0b8740..59771f0 100755
--- a/modules.d/45net-lib/net-lib.sh
+++ b/modules.d/45net-lib/net-lib.sh
@@ -426,6 +426,7 @@ parse_iscsi_root() {
     set $v
     IFS="$OLDIFS"
 
+    [ $# -ge 2 ] || return 0
     iscsi_protocol=$1
     shift # ignored
     iscsi_target_port=$1
diff --git a/modules.d/74iscsi/iscsiroot.sh b/modules.d/74iscsi/iscsiroot.sh
index 50b1025..087c106 100755
--- a/modules.d/74iscsi/iscsiroot.sh
+++ b/modules.d/74iscsi/iscsiroot.sh
@@ -301,7 +301,7 @@ if ! [ "$netif" = "online" ]; then
         for nroot in $(getargs netroot); do
             [ "${nroot%%:*}" = "iscsi" ] || continue
             nroot="${nroot##iscsi:}"
-            if [ -n "$nroot" ]; then
+            if [ -n "$nroot" ] && [ "$nroot" != "iscsi" ]; then
                 handle_netroot "$nroot"
                 ret=$((ret + $?))
             fi
