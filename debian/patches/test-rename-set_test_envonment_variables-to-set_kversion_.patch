From: Benjamin Drung <benjamin.drung@canonical.com>
Date: Fri, 27 Jun 2025 15:07:49 +0200
Subject: test: rename set_test_envonment_variables to
 set_kversion_and_vmlinux

The function `set_test_envonment_variables` contains a spelling mistake.
Rename it to `set_kversion_and_vmlinux` to make it more explicit.

Forwarded: https://github.com/dracut-ng/dracut-ng/pull/1398
---
 test/test-functions | 8 ++++----
 1 file changed, 4 insertions(+), 4 deletions(-)

diff --git a/test/test-functions b/test/test-functions
index ca776df..6b818fc 100644
--- a/test/test-functions
+++ b/test/test-functions
@@ -114,7 +114,7 @@ determine_kernel_version() {
     export KVERSION
 }
 
-set_test_envonment_variables() {
+set_kversion_and_vmlinux() {
     determine_kernel_version
 }
 
@@ -210,13 +210,13 @@ while (($# > 0)); do
     case $1 in
         --run)
             echo "TEST RUN: $TEST_DESCRIPTION"
-            set_test_envonment_variables
+            set_kversion_and_vmlinux
             test_check && test_run
             exit $?
             ;;
         --setup)
             echo "TEST SETUP: $TEST_DESCRIPTION"
-            set_test_envonment_variables
+            set_kversion_and_vmlinux
             test_check && test_setup
             exit $?
             ;;
@@ -228,7 +228,7 @@ while (($# > 0)); do
             exit $?
             ;;
         --all)
-            set_test_envonment_variables
+            set_kversion_and_vmlinux
             if ! test_check 2 &> test${TEST_RUN_ID:+-$TEST_RUN_ID}.log; then
                 if [[ ${V-} == "1" || ${V-} == "2" ]]; then
                     cat test${TEST_RUN_ID:+-$TEST_RUN_ID}.log
